# Copy this file to .env and fill in the values marked REQUIRED.
# Never commit .env to version control.

# --- Database ---
# Defaults to SQLite (no entry needed for local use).
# Uncomment and set this to switch to PostgreSQL:
# DATABASE_URL=postgresql://user:password@host:5432/firewatch

# --- Security (REQUIRED) ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Must be kept secret — changing this invalidates all existing sessions.
SECRET_KEY=change-me-generate-a-real-secret

# --- Token expiry ---
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- App behaviour ---
# Set to True to enable /docs and /redoc (useful during development)
DEBUG=True

# --- CORS ---
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# --- Frontend URL (used by SSO redirects after the OIDC callback) ---
FRONTEND_URL=http://localhost:3000

# --- SSO / OIDC (optional) ---
# Leave OIDC_ENABLED=False to disable SSO entirely. When enabled, all four of
# OIDC_DISCOVERY_URL, OIDC_CLIENT_ID, OIDC_CLIENT_SECRET, OIDC_REDIRECT_URI
# must be set or SSO stays effectively off (the /sso/login route will redirect
# to /login?sso_error=not_configured).
OIDC_ENABLED=False
# Display label on the SSO login button (e.g. "Google", "Okta", "Entra ID").
OIDC_PROVIDER_NAME=SSO
# OIDC discovery document, e.g.:
#   Google:    https://accounts.google.com/.well-known/openid-configuration
#   Microsoft: https://login.microsoftonline.com/<tenant>/v2.0/.well-known/openid-configuration
#   Okta:      https://<your-org>.okta.com/.well-known/openid-configuration
OIDC_DISCOVERY_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# Must match a redirect URI registered with the IdP. Defaults to the local dev value:
OIDC_REDIRECT_URI=http://localhost:8000/api/auth/sso/callback
# Space-separated list of scopes to request from the IdP.
OIDC_SCOPES=openid email profile
# Role assigned to JIT-provisioned users on first SSO login.
# Must be one of: admin, security_analyst, risk_owner, executive_viewer
OIDC_DEFAULT_ROLE=risk_owner

# --- OIDC role mapping (optional) ---
# Map IdP groups/roles to Firewatch roles. If OIDC_ROLE_MAP is empty, every SSO
# user gets OIDC_DEFAULT_ROLE. The user's role is REFRESHED FROM CLAIMS ON EVERY
# LOGIN — manual role edits in the UI will be overwritten on the next sign-in
# if the IdP claims resolve to a different role.
#
# Which claim to read. Common values:
#   "groups" — Entra group object IDs (GUIDs), Okta group names
#   "roles"  — Entra App Roles (RECOMMENDED for Entra: stable, human-readable)
OIDC_ROLE_CLAIM=groups
#
# JSON map: claim value → Firewatch role.
# Valid roles: admin, security_analyst, risk_owner, executive_viewer
#
# Entra App Roles example (set OIDC_ROLE_CLAIM=roles, define App Roles in the
# Entra app registration with values "Admin", "Analyst", etc.):
#   OIDC_ROLE_MAP={"Admin": "admin", "Analyst": "security_analyst", "Owner": "risk_owner"}
#
# Entra groups example (set OIDC_ROLE_CLAIM=groups, copy GUIDs from Azure portal):
#   OIDC_ROLE_MAP={"6c1d3e60-aaaa-bbbb-cccc-dddddddddddd": "admin"}
#
# Okta example (set OIDC_ROLE_CLAIM=groups, use group display names):
#   OIDC_ROLE_MAP={"firewatch-admins": "admin", "firewatch-analysts": "security_analyst"}
OIDC_ROLE_MAP={}

# --- CAEP / Continuous Access Evaluation (optional) ---
# When enabled, Firewatch accepts Security Event Tokens (SETs) pushed by a
# CAEP-compliant IdP (Okta, Entra via SSF API) to POST /api/auth/sso/caep.
# Events handled: session-revoked, credential-change → stamp last_logout_at;
# account-disabled, account-purged → deactivate the user immediately.
# Configure the receiver URL in your IdP's SSF/CAEP transmitter settings.
CAEP_ENABLED=False
# Optional: expected audience in the SET's aud claim. Defaults to OIDC_CLIENT_ID.
# CAEP_AUDIENCE=

# --- SCIM 2.0 provisioning (optional) ---
# When enabled, Firewatch exposes /api/scim/v2/* for IdP-driven user provisioning.
# Primary use case: Entra or Okta automatically deactivates users in Firewatch
# when accounts are offboarded in the IdP (via PATCH active=false).
# Generate a strong random token: python -c "import secrets; print(secrets.token_hex(32))"
# Set the same value as the Secret Token in your IdP's SCIM connector settings.
# Tenant URL (Entra): https://your-host/api/scim/v2
SCIM_ENABLED=False
# SCIM_BEARER_TOKEN=

# --- Initial admin setup ---
# Do NOT put credentials here. After starting the app for the first time,
# create the admin account interactively by running:
#
#   docker compose exec backend python seed_admin.py
#
# Credentials are entered at the terminal with masked input and never written to disk.
