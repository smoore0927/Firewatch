# Copy this file to .env and fill in the values marked REQUIRED.
# Never commit .env to version control.

# --- Database ---
# Defaults to SQLite (no entry needed for local use).
# Uncomment and set this to switch to PostgreSQL:
# DATABASE_URL=postgresql://user:password@host:5432/firewatch

# --- Security (REQUIRED) ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Must be kept secret — changing this invalidates all existing sessions.
SECRET_KEY=change-me-generate-a-real-secret

# --- Token expiry ---
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- App behaviour ---
# Set to True to enable /docs and /redoc (useful during development)
DEBUG=True

# --- CORS ---
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# --- Initial admin seed (optional) ---
# If set, creates this admin account on first startup if it doesn't exist.
# Safe to leave set — only runs when no matching user exists.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
